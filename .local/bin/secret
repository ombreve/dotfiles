#!/usr/bin/env bash
# secret : show paragraphs from secret file

usage() {
  echo "usage: ${0##*/} [-h] [regexp]"
}
cmdecho() {
  echo "${0##*/}: $@"
}

if [[ $# -eq 0 || $1 = "-h" ]]
then
  usage
  exit 0
fi

XFILE="${SECRET_FILE:-$HOME/Atelier/Arcanum.txt.dtc}"
if [[ ! -f "$XFILE" ]]
then
  cmdecho "cannot read secret file -- $XFILE" >&2
  exit 1
fi

udtc -dc $XFILE | sed -e '/./{H;$!d;}' -e 'x;/'"$1"'/!d'

