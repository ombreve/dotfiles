export PATH="$HOME/.local/bin:$PATH"

export PARINIT='rTbqRw66 B=.,?_A_a Q=_s>|'

umask 022

alias l='ls -FhH'
alias ll='l -l'
alias la='l -ial'
alias j='jobs'
alias d='dirs'
alias pu='pushd'
alias po='popd'
alias lm='latexmk'

alias dotfiles='git --git-dir=$HOME/Atelier/informatique/dotfiles.git --work-tree=$HOME'

alias rmdstore='find . -name ".DS_Store" -exec rm {} \;'

PS1='$ '
